{
  "name": "markrogoyski/numverify-api-client-php",
  "type": "library",
  "description": "Numverify API Client for PHP",
  "keywords": ["numverify", "api", "client", "phone number", "carrier lookup", "validate phone number", "country codes", "dialing codes"],
  "homepage": "https://github.com/markrogoyski/numverify-api-client-php/",
  "require": {
    "php": ">=8.2.0",
    "guzzlehttp/guzzle": "^7.0",
    "psr/http-message": "^1.0 || ^2.0"
  },
  "autoload": {
    "psr-4": { "Numverify\\": "src/" }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "php-coveralls/php-coveralls": "^2.7",
    "squizlabs/php_codesniffer": "^3.10",
    "phpstan/phpstan": "^2.0",
    "phpmd/phpmd": "^2.15",
    "php-parallel-lint/php-parallel-lint": "^1.4",
    "vimeo/psalm": "^6.14",
    "maglnet/composer-require-checker": "^4.17",
    "icanhazstring/composer-unused": "^0.9.5"
  },
  "autoload-dev": {
    "psr-4": { "Numverify\\Tests\\": "tests/" }
  },
  "authors": [
    {
      "name": "Mark Rogoyski",
      "email": "mark@rogoyski.com",
      "homepage": "https://github.com/markrogoyski",
      "role": "Lead developer"
    }
  ],
  "license": "MIT"
}
