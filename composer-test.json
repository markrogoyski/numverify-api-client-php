{
  "name": "markrogoyski/numverify-api-client-php",
  "type": "library",
  "description": "Minimal composer config for CI unit tests on PHP 8.2+",
  "license": "MIT",
  "require": {
    "php": ">=8.2.0",
    "guzzlehttp/guzzle": "^7.0",
    "psr/http-message": "^1.0 || ^2.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "php-parallel-lint/php-parallel-lint": "^1.4"
  },
  "autoload": {
    "psr-4": { "Numverify\\": "src/" }
  },
  "autoload-dev": {
    "psr-4": { "Numverify\\Tests\\": "tests/" }
  }
}
